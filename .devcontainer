{
  "name": "Node.js Proxy",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Proxy",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "postCreateCommand": "npm install"
}
